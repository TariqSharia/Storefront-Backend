{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "tsc && node dist/server.js",
    "watch": "tsc-watch --esModuleInterop src/server.ts --outDir ./dist --onSuccess \"node ./dist/server.js\"",
    "test": "dotenv -e .env -- cross-env ENV=test yarn tsc && dotenv -e .env -- cross-env ENV=test jasmine",
    "tsc": "tsc",
    "migrate": "dotenv -e .env -- db-migrate up",
    "migrate-test": "dotenv -e .env -- db-migrate up --env test",
    "migrate-down": "dotenv -e .env -- db-migrate down",
    "migrate-down-test": "dotenv -e .env -- db-migrate down --env test"
  },
  "author": "Udacity",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.19.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typescript": "^5.9.3",
    "yarn": "^1.22.22"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jasmine": "4.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "jasmine": "4.6.0",
    "jasmine-spec-reporter": "^7.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-watch": "^4.2.9"
  }
}
